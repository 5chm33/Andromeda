# ─────────────────────────────────────────────────────────────────────────────
# Andromeda v12.5.0 — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_me_to_a_long_random_string
ANDROMEDA_ADMIN_KEY=change_me_to_a_long_random_string
VITE_APP_TITLE=Andromeda AI

# ── LLM Provider (at least one required) ─────────────────────────────────────
# OpenRouter (recommended — routes to GPT-4o, Claude, Gemini, etc.)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# Anthropic Claude (optional — used for RSI improvement proposals)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (optional — cost-effective for RSI cycles)
DEEPSEEK_API_KEY=sk-...

# Moonshot Kimi (optional)
KIMI_API_KEY=...

# ── GitHub Integration ────────────────────────────────────────────────────────
# Required for RSI auto-commit and "Fix Any GitHub Repo" feature
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name

# ── Media Generation ──────────────────────────────────────────────────────────
# fal.ai — image and video generation (required for media features)
FAL_KEY=...

# Hugging Face (optional — for open-source model inference)
HF_TOKEN=hf_...

# ── Search ────────────────────────────────────────────────────────────────────
# Brave Search API (optional — enables web search tool)
BRAVE_SEARCH_API_KEY=BSA...
BRAVE_SEARCH_ENABLED=true

# ── RSI (Recursive Self-Improvement) ─────────────────────────────────────────
# Enable continuous self-improvement (true/false)
CONTINUOUS_IMPROVE=false

# Auto-rebuild after RSI commits (true/false)
AUTO_REBUILD=false

# Auto-generate improvement goals (true/false)
AUTO_GOALS=false

# Minimum confidence score for auto-applying proposals (0.0–1.0)
PR_MIN_CONFIDENCE=0.85

# Auto-merge PRs that pass all checks (true/false)
PR_AUTO_MERGE=false

# ── Autonomy ──────────────────────────────────────────────────────────────────
# Enable autonomous agent mode (true/false)
AUTONOMY=false

# Autonomy cycle interval in milliseconds (default: 60000 = 1 minute)
AUTONOMY_CYCLE_MS=60000

# Max actions per autonomy cycle
AUTONOMY_MAX_ACTIONS=10

# Require human approval before executing autonomy actions (true/false)
AUTONOMY_REQUIRE_APPROVAL=true

# ── Advanced / Experimental ───────────────────────────────────────────────────
# Allow RSI to modify any file in the filesystem (DANGEROUS — default: false)
ALLOW_FULL_FS=false

# Unlock meta-modification (RSI can modify its own safety modules — DANGEROUS)
META_MODIFY_UNLOCK=false

# Enable multi-agent review for proposals (true/false)
MULTI_AGENT_REVIEW=false

# ── v101.0.0 Additions ────────────────────────────────────────────────────────
# Local Ollama inference (free, no API key needed)
# Start with: docker-compose --profile local-llm up -d
OLLAMA_BASE_URL=http://localhost:11434

# Redis cache (auto-configured in docker-compose)
# REDIS_URL=redis://localhost:6379
# ── REST API / Webhook ────────────────────────────────────────────────────────
# API key for the external REST API layer (auto-generated if not set)
ANDROMEDA_API_KEY=change_me_to_a_long_random_string
# HMAC secret for webhook callback signatures (auto-generated if not set)
ANDROMEDA_HMAC_SECRET=change_me_to_a_long_random_string

# ── SWE-Bench Model Overrides ─────────────────────────────────────────────────
# Override the base/mid/strong model used by the SWE-Bench solver
SWEBENCH_BASE_MODEL=claude-sonnet-4-5
SWEBENCH_MID_MODEL=claude-sonnet-5
SWEBENCH_STRONG_MODEL=fable-5
