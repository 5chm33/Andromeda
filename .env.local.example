# ============================================================
#  Andromeda AI v6.17 — Configuration
#  Copy this file to .env.local and fill in your API keys.
#  Lines starting with # are comments and are ignored.
# ============================================================

# ─── COST WARNING ────────────────────────────────────────────────────────────
# v6.17: DeepSeek is the default provider. It costs ~$0.14/M input tokens.
# DO NOT set LLM_MODEL=openrouter unless you intend to use Claude Opus ($15/M).
# Background daemons (self-improve, goal engine) always use DeepSeek — NOT OpenRouter.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: Primary LLM ────────────────────────────────────────────────────
# DeepSeek API Key — the main chat and agent engine
# Cost: ~$0.14/M input, $0.28/M output (extremely cheap)
# Get yours FREE at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── REQUIRED: Web Search ─────────────────────────────────────────────────────
# Brave Search API Key (web search — 2000 free queries/month)
# Get yours at: https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ── OPTIONAL: LLM Provider Selection ─────────────────────────────────────────
# Which model to use for chat. Default (when unset): deepseek
# Options: deepseek | deepseek-reasoner | kimi | openrouter | openrouter-fast | openai | groq
# WARNING: openrouter defaults to Claude Opus 4.6 (~$15/M tokens — very expensive)
# Leave this UNSET to use DeepSeek automatically when DEEPSEEK_API_KEY is set.
# LLM_MODEL=deepseek

# ── OPTIONAL: Additional LLM Providers ───────────────────────────────────────
# OpenRouter — enables Claude, Gemini, and 100+ models via tier selector
# WARNING: If LLM_MODEL=openrouter, ALL chat goes through Claude Opus at $15/M tokens
# Only set this if you specifically want to use OpenRouter models
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model override (only used when LLM_MODEL=openrouter)
# Use a cheaper model: google/gemini-2.5-flash, deepseek/deepseek-chat
# OPENROUTER_MODEL=google/gemini-2.5-flash

# Kimi k2.6 — best for coding tasks (used by Code tier)
# Get yours at: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# Groq — ultra-fast inference (used by Fast tier)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Anthropic — Claude direct API (alternative to OpenRouter)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — GPT-4 (optional alternative)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── OPTIONAL: Custom LLM Endpoint ────────────────────────────────────────────
# Override the LLM endpoint (e.g., for local Ollama or LM Studio)
# LLM_API_URL=http://localhost:11434/v1
# LLM_API_KEY=your_custom_key
# LLM_DEFAULT_MODEL=deepseek-chat

# ── OPTIONAL: Search Enhancements ────────────────────────────────────────────
# Tavily Search (premium search API — better results)
# Get yours at: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Custom SearXNG instance (self-hosted fallback)
# SEARXNG_URL=http://localhost:8888

# ── OPTIONAL: Cloud Sandbox ──────────────────────────────────────────────────
# E2B API Key (cloud sandbox execution when Docker is unavailable)
# Get yours at: https://e2b.dev/docs
ANDROMEDA_E2B_API_KEY=your_e2b_api_key_here

# ── AUTONOMY SETTINGS ─────────────────────────────────────────────────────────
# Background daemons (self-improve, goal engine) use DeepSeek regardless of LLM_MODEL.
CONTINUOUS_IMPROVE=true
AUTO_GOALS=true
MULTI_AGENT_REVIEW=true
ALLOW_FULL_FS=true
AUTONOMY=true
AUTONOMY_CYCLE_MS=60000
AUTONOMY_MAX_ACTIONS=5
AUTONOMY_REQUIRE_APPROVAL=false

# ── SECURITY ──────────────────────────────────────────────────────────────────
# v6.17: Auth is ENABLED by default. Set to false for local dev only.
# AUTH_ENABLED=false
JWT_SECRET=andromeda-local-secret-key

# ── ADVANCED: Server Settings ─────────────────────────────────────────────────
# PORT=3000
# LOG_LEVEL=info

# ── HUGGING FACE ──────────────────────────────────────────────────────────────
# Optional: for downloading local embedding models
# HF_TOKEN=your_hf_token_here
