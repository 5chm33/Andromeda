    "test:federated": "npx tsx scripts/simulate-federated.ts",
    "test:eval": "npx tsx scripts/run-eval.ts",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "daemon:start": "node dist/andromedaDaemon.js",
    "daemon:stop": "node dist/andromedaDaemon.js stop",
    "daemon:status": "node dist/andromedaDaemon.js status",
    "daemon:install": "bash scripts/install_daemon.sh install",
    "daemon:uninstall": "bash scripts/install_daemon.sh uninstall",
    "daemon:logs": "bash scripts/install_daemon.sh logs"
